# PostgreSQL connection
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password_here
PGDATABASE=happyland_estate

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Supabase project (Settings > API in the Supabase dashboard).
# The publishable key is safe to expose to the browser (NEXT_PUBLIC_*).
# The app still runs its own login/session logic via PGHOST/etc + JWT_SECRET
# above — these vars only enable the Supabase client/server/middleware
# scaffolding in frontend/lib/supabaseClient.js, backend/supabase.js, and
# middleware.js. Leaving them blank disables that scaffolding, not the app.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key (Settings > API > secret keys) — server-only, bypasses RLS.
# Only needed if/when server code needs elevated access. Never expose to the browser.
SUPABASE_SECRET_KEY=
